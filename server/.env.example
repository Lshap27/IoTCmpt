AIOT_APP_ENV=dev
AIOT_DATABASE_URL=postgresql+psycopg://aiot:aiot@127.0.0.1:5432/aiot
AIOT_AUTO_CREATE_TABLES=true
AIOT_BASE_URL=http://127.0.0.1:8000
AIOT_MAX_IMAGES_PER_DEVICE=100
AIOT_UPLOADS_DIR=uploads
AIOT_POSE_ENABLED=false
AIOT_POSE_MODEL_PATH=models/pose_landmarker_lite.task
AIOT_POSE_MIN_CONFIDENCE=0.3
AIOT_MQTT_ENABLED=true
AIOT_MQTT_HOST=127.0.0.1
AIOT_MQTT_PORT=1883
AIOT_MQTT_CLIENT_ID=aiot-gateway
AIOT_MQTT_USERNAME=
AIOT_MQTT_PASSWORD=
AIOT_CORS_ORIGINS=http://localhost:3000

# ---- LLM（OpenAI 兼容 chat/completions，支持视觉多模态）----
# 设为 mock 可在无 API key / 断网时演示完整 AI 决策闭环。
# 常见厂商 endpoint 示例：
#   阿里云 DashScope: https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions   （模型示例 qwen-vl-plus）
#   智谱开放平台:     https://open.bigmodel.cn/api/paas/v4/chat/completions                （模型示例 glm-4v-flash）
#   OpenAI:          https://api.openai.com/v1/chat/completions                            （模型示例 gpt-4o-mini）
AIOT_LLM_ENDPOINT=
AIOT_LLM_API_KEY=
AIOT_LLM_MODEL=demo-model
AIOT_LLM_TIMEOUT_SECONDS=12
# 是否把设备最新照片（base64）附给模型
AIOT_LLM_VISION_ENABLED=true
# 最新照片超过该秒数视为过期，不再附图
AIOT_LLM_IMAGE_MAX_AGE_SECONDS=600
# json_object | json_schema | none（json_schema 需厂商支持 OpenAI structured outputs）
AIOT_LLM_RESPONSE_FORMAT=json_object

# ---- 自动决策闭环（autopilot）----
AIOT_AUTOPILOT_ENABLED=true
AIOT_AUTOPILOT_COOLDOWN_SECONDS=120
# 置信度低于该值的 AI 命令只入库为建议，不经 MQTT 下发
AIOT_AUTOPILOT_MIN_CONFIDENCE=0.6
# 触发自动分析的空气质量级别（逗号分隔，可选 good/watch/alert）
AIOT_AUTOPILOT_TRIGGER_LEVELS=alert
