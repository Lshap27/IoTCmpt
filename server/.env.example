AIOT_APP_ENV=dev
AIOT_DATABASE_URL=postgresql+psycopg://aiot:aiot@127.0.0.1:5432/aiot
AIOT_AUTO_CREATE_TABLES=true
AIOT_BASE_URL=http://127.0.0.1:8000
AIOT_MAX_IMAGES_PER_DEVICE=100
AIOT_UPLOADS_DIR=uploads
AIOT_POSE_ENABLED=false
AIOT_POSE_MODEL_PATH=models/pose_landmarker_full.task
AIOT_POSE_DETECTION_CONFIDENCE=0.3
AIOT_POSE_PRESENCE_CONFIDENCE=0.3
AIOT_POSE_TRACKING_CONFIDENCE=0.3
AIOT_POSE_LANDMARK_VISIBILITY=0.5
AIOT_POSE_FORWARD_LEAN_DEGREES=20
AIOT_POSE_HUNCH_RATIO=0.25
AIOT_POSE_HEAD_DOWN_DEGREES=25
AIOT_PERSON_DETECTION_ENABLED=true
AIOT_PERSON_DETECTION_MODEL_PATH=models/efficientdet_lite0_int8.tflite
AIOT_PERSON_DETECTION_CONFIDENCE=0.35
AIOT_MQTT_ENABLED=true
AIOT_MQTT_HOST=127.0.0.1
AIOT_MQTT_PORT=1883
AIOT_COMMAND_ACK_TIMEOUT_SECONDS=60
AIOT_MQTT_CLIENT_ID=aiot-gateway
AIOT_MQTT_USERNAME=
AIOT_MQTT_PASSWORD=
AIOT_CORS_ORIGINS=http://localhost:3000

# ---- MCP（内部 Token 由配置工具生成；对外启用时必须再设置两个不同 Token）----
AIOT_MCP_INTERNAL_TOKEN=replace-with-generated-random-token
AIOT_MCP_ENABLED=false
AIOT_MCP_READ_TOKEN=
AIOT_MCP_CONTROL_TOKEN=
AIOT_MCP_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
AIOT_MCP_ALLOWED_HOSTS=localhost,127.0.0.1
AIOT_MCP_RATE_LIMIT_PER_MINUTE=60

# ---- 异步 AI 任务与巡检 ----
AIOT_AI_WORKER_ENABLED=true
AIOT_AI_WORKER_POLL_SECONDS=0.5
AIOT_AI_WORKER_LEASE_SECONDS=90
AIOT_AI_WORKER_HEARTBEAT_SECONDS=15
AIOT_AI_WORKER_MAX_ATTEMPTS=3
AIOT_AI_TOOL_MAX_ROUNDS=4
AIOT_AI_TOOL_MAX_CALLS=8
AIOT_PATROL_SCHEDULER_SECONDS=5
AIOT_AUTOMATION_SCHEDULER_SECONDS=1
AIOT_GATEWAY_INTERNAL_URL=http://127.0.0.1:8000
AIOT_OUTBOX_LEASE_SECONDS=30

# ---- LLM（填写 OpenAI 兼容 base URL，程序自动追加 /chat/completions）----
# 设为 mock 可在无 API key / 断网时演示完整 AI 决策闭环。
# 常见厂商 base URL 示例；仍兼容旧版完整 /chat/completions 地址：
#   DeepSeek:        https://api.deepseek.com                              （默认模型 deepseek-v4-flash；关闭视觉）
#   OpenAI:          https://api.openai.com/v1                              （模型示例 gpt-4o-mini）
#   阿里云 DashScope: https://dashscope.aliyuncs.com/compatible-mode/v1     （模型示例 qwen-vl-plus）
#   智谱开放平台:     https://open.bigmodel.cn/api/paas/v4                  （模型示例 glm-4v-flash）
AIOT_LLM_ENDPOINT=https://api.deepseek.com
AIOT_LLM_API_KEY=
AIOT_LLM_MODEL=deepseek-v4-flash
AIOT_LLM_TIMEOUT_SECONDS=60
# 是否把设备最新照片（base64）附给模型
# 最新照片超过该秒数视为过期，不再附图
AIOT_LLM_IMAGE_MAX_AGE_SECONDS=600
# json_object | json_schema | none（json_schema 需厂商支持 OpenAI structured outputs）
AIOT_LLM_RESPONSE_FORMAT=json_object
# DeepSeek V4 可开启思考模式；其他兼容端点不支持时保持 false
AIOT_LLM_THINKING_ENABLED=false
AIOT_LLM_REASONING_EFFORT=high

AIOT_VISION_IMAGE_MAX_AGE_SECONDS=15
