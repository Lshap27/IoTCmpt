menu "S3 Sensor Cloud"

    config APP_SENSOR_MOCK_ENABLED
        bool "Use mock sensor samples"
        default y

    config APP_SENSOR_INTERVAL_MS
        int "Sensor loop interval in milliseconds"
        default 5000
        range 1000 60000

    config APP_WIFI_ENABLED
        bool "Enable Wi-Fi station connection"
        default n

    config APP_WIFI_SSID
        string "Wi-Fi SSID"
        default ""

    config APP_WIFI_PASSWORD
        string "Wi-Fi password"
        default ""

    config APP_CLOUD_ENABLED
        bool "Enable cloud LLM exchange"
        default n

    config APP_CLOUD_ENDPOINT
        string "Cloud LLM endpoint"
        default ""

    config APP_CLOUD_MODEL
        string "Cloud LLM model"
        default "demo-model"

    config APP_CLOUD_TOKEN
        string "Cloud LLM bearer token"
        default ""

    menu "Backend upload"
        config APP_BACKEND_ENABLED
            bool "Enable ordinary backend uploads"
            default n

        config APP_SENSOR_UPLOAD_URL
            string "Sensor JSON upload URL"
            default ""

        config APP_IMAGE_UPLOAD_URL
            string "Camera image upload URL"
            default ""

        config APP_POSE_UPLOAD_URL
            string "Pose detection upload URL"
            default ""
    endmenu

    menu "Feature modules"
        config APP_CAMERA_ENABLED
            bool "Enable OV2640 camera task"
            default n

        config APP_DISPLAY_ENABLED
            bool "Enable ST7735 display task"
            default n

        config APP_ACTUATOR_ENABLED
            bool "Enable servo and beeper actuator task"
            default n

        config APP_BUTTON_ENABLED
            bool "Enable manual button task"
            default n
    endmenu

    menu "Sensor pins"
        config APP_SHT30_SDA_GPIO
            int "SHT30 software I2C SDA GPIO"
            default 1

        config APP_SHT30_SCL_GPIO
            int "SHT30 software I2C SCL GPIO"
            default 2

        config APP_TVOC_UART_NUM
            int "TVOC301 UART number"
            default 2

        config APP_TVOC_TX_GPIO
            int "TVOC301 UART TX GPIO"
            default 19

        config APP_TVOC_RX_GPIO
            int "TVOC301 UART RX GPIO"
            default 20

        config APP_LM393_DO_GPIO
            int "LM393 digital output GPIO"
            default 4
    endmenu

    menu "Actuator and input pins"
        config APP_SERVO_GPIO
            int "SG90 servo signal GPIO"
            default 36

        config APP_BUTTON_GPIO
            int "Manual toggle button GPIO"
            default 21

        config APP_BEEP_GPIO
            int "Active beeper GPIO"
            default 35

        config APP_BEEP_ACTIVE_LOW
            bool "Beeper is active low"
            default y
    endmenu

    menu "Display pins"
        config APP_TFT_MOSI_GPIO
            int "ST7735 MOSI GPIO"
            default 6

        config APP_TFT_SCLK_GPIO
            int "ST7735 SCLK GPIO"
            default 8

        config APP_TFT_CS_GPIO
            int "ST7735 CS GPIO"
            default 5
            help
                Teammate prototype used GPIO10, which conflicts with the
                verified camera XCLK pin. Set this to the board's actual TFT CS.

        config APP_TFT_DC_GPIO
            int "ST7735 DC GPIO"
            default 9

        config APP_TFT_RST_GPIO
            int "ST7735 reset GPIO"
            default 46

        config APP_TFT_BLK_GPIO
            int "ST7735 backlight GPIO"
            default 7
    endmenu

    menu "Camera pins"
        config APP_CAMERA_XCLK_GPIO
            int "OV2640 XCLK GPIO"
            default 10

        config APP_CAMERA_SIOD_GPIO
            int "OV2640 SIOD GPIO"
            default 40

        config APP_CAMERA_SIOC_GPIO
            int "OV2640 SIOC GPIO"
            default 39

        config APP_CAMERA_D0_GPIO
            int "OV2640 D0 GPIO"
            default 15

        config APP_CAMERA_D1_GPIO
            int "OV2640 D1 GPIO"
            default 17

        config APP_CAMERA_D2_GPIO
            int "OV2640 D2 GPIO"
            default 18

        config APP_CAMERA_D3_GPIO
            int "OV2640 D3 GPIO"
            default 16

        config APP_CAMERA_D4_GPIO
            int "OV2640 D4 GPIO"
            default 14

        config APP_CAMERA_D5_GPIO
            int "OV2640 D5 GPIO"
            default 12

        config APP_CAMERA_D6_GPIO
            int "OV2640 D6 GPIO"
            default 11

        config APP_CAMERA_D7_GPIO
            int "OV2640 D7 GPIO"
            default 48

        config APP_CAMERA_VSYNC_GPIO
            int "OV2640 VSYNC GPIO"
            default 38

        config APP_CAMERA_HREF_GPIO
            int "OV2640 HREF GPIO"
            default 47

        config APP_CAMERA_PCLK_GPIO
            int "OV2640 PCLK GPIO"
            default 13
    endmenu

