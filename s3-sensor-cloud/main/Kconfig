menu "S3 传感器云端控制"

    config APP_SENSOR_MOCK_ENABLED
        bool "使用模拟传感器数据"
        default y

    config APP_SENSOR_INTERVAL_MS
        int "传感器循环间隔（毫秒）"
        default 5000
        range 1000 60000

    config APP_WIFI_ENABLED
        bool "启用 Wi-Fi 连接"
        default n

    config APP_WIFI_SSID
        string "Wi-Fi 名称（SSID）"
        default ""

    config APP_WIFI_PASSWORD
        string "Wi-Fi 密码"
        default ""

    config APP_CLOUD_ENABLED
        bool "启用云端大模型交互"
        default n

    config APP_CLOUD_ENDPOINT
        string "云端大模型接口地址"
        default ""

    config APP_CLOUD_MODEL
        string "云端大模型名称"
        default "demo-model"

    config APP_CLOUD_TOKEN
        string "云端大模型访问令牌"
        default ""

    menu "后端上传"
        config APP_BACKEND_ENABLED
            bool "启用普通后端上传"
            default n

        config APP_SENSOR_UPLOAD_URL
            string "传感器 JSON 上传地址"
            default ""

        config APP_IMAGE_UPLOAD_URL
            string "摄像头图片上传地址"
            default ""

        config APP_POSE_UPLOAD_URL
            string "姿态检测上传地址"
            default ""
    endmenu

    menu "功能模块"
        config APP_CAMERA_ENABLED
            bool "启用 OV2640 摄像头任务"
            default n

        config APP_DISPLAY_ENABLED
            bool "启用 ST7735 显示屏任务"
            default n

        config APP_ACTUATOR_ENABLED
            bool "启用舵机和蜂鸣器执行任务"
            default n

        config APP_BUTTON_ENABLED
            bool "启用手动按键任务"
            default n
    endmenu

    menu "传感器引脚"
        config APP_SHT30_SDA_GPIO
            int "SHT30 软件 I2C SDA 引脚"
            default 1

        config APP_SHT30_SCL_GPIO
            int "SHT30 软件 I2C SCL 引脚"
            default 2

        config APP_TVOC_UART_NUM
            int "TVOC301 使用的 UART 编号"
            default 2

        config APP_TVOC_TX_GPIO
            int "TVOC301 UART TX 引脚"
            default 19

        config APP_TVOC_RX_GPIO
            int "TVOC301 UART RX 引脚"
            default 20

        config APP_LM393_DO_GPIO
            int "LM393 数字输出引脚"
            default 4
    endmenu

    menu "执行器和输入引脚"
        config APP_SERVO_GPIO
            int "SG90 舵机信号引脚"
            default 36

        config APP_BUTTON_GPIO
            int "手动切换按键引脚"
            default 21

        config APP_BEEP_GPIO
            int "有源蜂鸣器引脚"
            default 35

        config APP_BEEP_ACTIVE_LOW
            bool "蜂鸣器低电平触发"
            default y
    endmenu

    menu "显示屏引脚"
        config APP_TFT_MOSI_GPIO
            int "ST7735 MOSI 引脚"
            default 6

        config APP_TFT_SCLK_GPIO
            int "ST7735 SCLK 引脚"
            default 8

        config APP_TFT_CS_GPIO
            int "ST7735 CS 片选引脚"
            default 5
            help
                队友原型曾使用 GPIO10 作为 TFT CS，但 GPIO10 同时也是
                已验证摄像头 XCLK 引脚。请按实际接线设置 TFT CS。

        config APP_TFT_DC_GPIO
            int "ST7735 DC 引脚"
            default 9

        config APP_TFT_RST_GPIO
            int "ST7735 复位引脚"
            default 46

        config APP_TFT_BLK_GPIO
            int "ST7735 背光引脚"
            default 7
    endmenu

