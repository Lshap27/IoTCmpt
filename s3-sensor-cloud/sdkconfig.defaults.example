# Copy selected values into sdkconfig.defaults or configure them with menuconfig.
# Do not store real secrets in Git.

CONFIG_ESPTOOLPY_FLASHSIZE_8MB=y

CONFIG_APP_SENSOR_MOCK_ENABLED=y
CONFIG_APP_SENSOR_INTERVAL_MS=5000
CONFIG_APP_WIFI_ENABLED=n
CONFIG_APP_CLOUD_ENABLED=n
CONFIG_APP_CLOUD_MODEL="demo-model"
