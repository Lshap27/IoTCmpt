{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iotcmpt.local/contracts/automation-plan.schema.json",
  "title": "IoTCmpt Automation Plan v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "title",
    "duration_seconds",
    "timezone",
    "manual_override_policy",
    "end_behavior",
    "clarifications",
    "rules"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "title": {"type": "string", "minLength": 1, "maxLength": 120},
    "duration_seconds": {"type": "integer", "minimum": 60, "maximum": 86400},
    "timezone": {"type": "string", "minLength": 1, "maxLength": 64},
    "manual_override_policy": {"const": "respect"},
    "end_behavior": {"const": "keep_state"},
    "clarifications": {
      "type": "array",
      "maxItems": 5,
      "items": {"type": "string", "minLength": 1, "maxLength": 240}
    },
    "rules": {
      "type": "array",
      "maxItems": 16,
      "items": {"$ref": "#/$defs/rule"}
    }
  },
  "allOf": [
    {
      "if": {"properties": {"rules": {"maxItems": 0}}},
      "then": {"properties": {"clarifications": {"minItems": 1}}}
    }
  ],
  "$defs": {
    "predicate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fact", "op", "value"],
      "properties": {
        "fact": {
          "enum": [
            "light_is_dark",
            "human_present",
            "air_quality",
            "recommend_open_window",
            "temperature_c",
            "humidity_percent",
            "tvoc_ppb",
            "hcho_ug_m3",
            "eco2_ppm",
            "window_open",
            "led_on",
            "device_status"
          ]
        },
        "op": {"enum": ["eq", "in", "gt", "gte", "lt", "lte"]},
        "value": {}
      }
    },
    "conditionTrigger": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "mode", "items", "stability_samples"],
      "properties": {
        "type": {"const": "condition"},
        "mode": {"enum": ["all", "any"]},
        "items": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": {"$ref": "#/$defs/predicate"}
        },
        "stability_samples": {"type": "integer", "minimum": 1, "maximum": 5}
      }
    },
    "intervalTrigger": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "every_seconds"],
      "properties": {
        "type": {"const": "interval"},
        "every_seconds": {"type": "integer", "minimum": 15, "maximum": 86400}
      }
    },
    "delayTrigger": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "after_seconds"],
      "properties": {
        "type": {"const": "delay"},
        "after_seconds": {"type": "integer", "minimum": 15, "maximum": 86400}
      }
    },
    "emptyParameter": {
      "type": "object",
      "additionalProperties": false,
      "properties": {}
    },
    "stateAction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "parameter"],
      "properties": {
        "command": {"enum": ["window.open", "window.close", "led.on", "led.off"]},
        "parameter": {"$ref": "#/$defs/emptyParameter"}
      }
    },
    "voiceAction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "parameter", "text"],
      "properties": {
        "command": {"const": "voice.speak"},
        "parameter": {"$ref": "#/$defs/emptyParameter"},
        "text": {"type": "string", "minLength": 1, "maxLength": 60}
      }
    },
    "displayAction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "parameter"],
      "properties": {
        "command": {"const": "display.message"},
        "parameter": {
          "type": "object",
          "additionalProperties": false,
          "required": ["text"],
          "properties": {"text": {"type": "string", "minLength": 1, "maxLength": 120}}
        },
        "text": {"type": "string", "minLength": 1, "maxLength": 120}
      }
    },
    "action": {
      "oneOf": [
        {"$ref": "#/$defs/stateAction"},
        {"$ref": "#/$defs/voiceAction"},
        {"$ref": "#/$defs/displayAction"}
      ]
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "trigger", "action", "cooldown_seconds"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z][a-z0-9_-]{0,47}$"},
        "description": {"type": "string", "minLength": 1, "maxLength": 240},
        "trigger": {
          "oneOf": [
            {"$ref": "#/$defs/conditionTrigger"},
            {"$ref": "#/$defs/intervalTrigger"},
            {"$ref": "#/$defs/delayTrigger"}
          ]
        },
        "action": {"$ref": "#/$defs/action"},
        "cooldown_seconds": {"type": "integer", "minimum": 0, "maximum": 86400}
      }
    }
  }
}
