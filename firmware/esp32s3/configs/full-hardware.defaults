CONFIG_APP_MQTT_ENABLED=n
CONFIG_APP_IMAGE_UPLOAD_ENABLED=n
CONFIG_APP_CAMERA_ENABLED=y
CONFIG_APP_DISPLAY_ENABLED=y
CONFIG_APP_ACTUATOR_ENABLED=y
CONFIG_APP_BUTTON_ENABLED=y
CONFIG_APP_MQ2_ENABLED=y
CONFIG_APP_VOICE_ENABLED=y
CONFIG_APP_LED_MODE_GPIO=y
CONFIG_APP_LED_GPIO=41
CONFIG_APP_LED_ACTIVE_LOW=n
CONFIG_PARTITION_TABLE_SINGLE_APP_LARGE=y
