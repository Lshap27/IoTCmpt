!server/.python-version
.venv/
venv/
env/
server/.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
server/.pytest-tmp/
server/test*.db
server/uploads/
server/captured_images/

